# Elasticsearch
ELASTICSEARCH_URL=http://your-es-host:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=CHANGE_ME
ELASTICSEARCH_INDEX_PATTERN=logs-*

# APM
APM_INDEX_PATTERN=apm-*

# Prometheus
PROMETHEUS_URL=http://your-prometheus:9090

# Kubernetes (leave KUBECONFIG_PATH empty for in-cluster)
KUBECONFIG_PATH=
K8S_NAMESPACES=["default","production"]

# Alerting
ALERT_CHECK_INTERVAL_SECONDS=30
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=[]
ALERT_WEBHOOK_URL=

# App
CORS_ORIGINS=["http://localhost:3000"]
POLL_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=5

# Authentication
# Generate secret: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_ENABLED=true
AUTH_SECRET=
# Generate API key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=[]
# Allowed webhook hosts (empty = block internal IPs only; set to restrict further)
ALLOWED_WEBHOOK_HOSTS=[]

# AI / LLM (Claude API for Triage Card generation)
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# SLO Reporting
SLO_REPORT_ENABLED=true
SLO_REPORT_HOUR=9
SLO_REPORT_TIMEZONE=Asia/Ho_Chi_Minh
